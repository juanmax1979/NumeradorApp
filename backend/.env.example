PORT=4000

SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=NumeradorDB
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong!Passw0rd
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_CERT=true

# Base SIGI (stored procedures procNumerador*)
SIGI_SQLSERVER_HOST=localhost
SIGI_SQLSERVER_PORT=1433
SIGI_SQLSERVER_DATABASE=SigiDB
SIGI_SQLSERVER_USER=sa
SIGI_SQLSERVER_PASSWORD=change_me
SIGI_SQLSERVER_ENCRYPT=false
SIGI_SQLSERVER_TRUST_CERT=true

# Parámetros de SP (por defecto coinciden con los contratos actuales)
SIGI_SP_USUARIO_DNI_PARAM=dniUsuarioSigi
SIGI_SP_EXPEDIENTE_PARAM=NroExpediente

JWT_SECRET=super_secret_jwt_key_change_me
JWT_ACCESS_EXPIRES=20m
JWT_REFRESH_EXPIRES_DAYS=7
BCRYPT_ROUNDS=12

# Auth provider: local | ad
AUTH_PROVIDER=local
AD_AUTO_PROVISION=true
AD_DEFAULT_ROLE=user
AD_DEFAULT_DEPENDENCIA=GENERAL

# Active Directory / LDAP
AD_URL=ldap://dc01.mi-organizacion.local:389
AD_BASE_DN=DC=mi-organizacion,DC=local
AD_BIND_DN=
AD_BIND_PASSWORD=
AD_USER_FILTER=(sAMAccountName={{username}})
AD_DNI_ATTRIBUTE=employeeID
AD_DNI_FALLBACK_ATTRIBUTES=employeeNumber,serialNumber
AD_FULLNAME_ATTRIBUTE=displayName
# Si no usas AD_BIND_DN, se intentara bind directo con usuario@AD_UPN_SUFFIX
AD_UPN_SUFFIX=mi-organizacion.local

# Origen único permitido (compatibilidad)
FRONTEND_URL=http://localhost:5173
# Múltiples orígenes permitidos, separados por coma (tiene prioridad sobre FRONTEND_URL)
FRONTEND_URLS=http://localhost:5173,http://192.168.56.1:5174,http://localhost:4000
COOKIE_SECURE=false
